# Overrides locales para deploy/install-ionos-plesk.sh
# ---------------------------------------------------------------------------
# Copia este fichero a  deploy/deploy.local.env  y pon TUS valores reales.
# deploy.local.env está en .gitignore: NO se publica en el repo.
#
#   cp deploy/deploy.local.env.example deploy/deploy.local.env
#   # edita deploy/deploy.local.env
#   sudo bash deploy/install-ionos-plesk.sh
# ---------------------------------------------------------------------------

# Subdominio de la app (FQDN)
DOMAIN="md.tudominio.es"

# Carpeta del subdominio en Plesk (la que ves en "Carpeta de inicio")
BASE_DIR="/var/www/vhosts/tudominio.es/md.tudominio.es"

# Puerto local del servicio (cámbialo solo si el 8000 está ocupado)
PORT="8000"
